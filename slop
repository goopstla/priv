function Dodge()
    keyrelease(DodgeKey)
    keyrelease(ParryKey)
    keypress(DodgeKey)
    keyrelease(DodgeKey)
    mouse2click()
end

function BlockStart(now, duration)
    local timestamp = now or os.clock()
    local holdTime = duration or ReleaseTime

    ReleaseDeadline = timestamp + holdTime   
    KeyHeld = true
    CooldownActive = true
    LastParryTime = timestamp
    
    if AutoParryToggle.Get() == true then
        if ismouse1pressed() then mouse2click() end
        keypress(ParryKey)
    end
end

function BlockEnd()
    KeyHeld = false
    ReleaseDeadline = 0
    ParrySuccess = false
    
    if AutoParryToggle.Get() == true then 
        keyrelease(ParryKey)
    end 
end

function ParryTask()
    local now = os.clock()
    if KeyHeld then
        if (now >= ReleaseDeadline) or ParrySuccess then
            ParrySuccess = false
            BlockEnd()
        end
    end

    if PendingParryTimestamp then
        if (now - PendingParryTimestamp) > ParryWindow then
            PendingParryTimestamp = nil
        elseif not CooldownActive then
            BlockStart(now)
            PendingParryTimestamp = nil
        end
    end
end

local function onLocalAnimationAdded(anim)
    local animId = anim.AnimationId
    if table.find(ParriedAnimation, animId) then 
        ParrySuccess = true
        CooldownActive = false
    end

    if table.find(StunnedAnimation, animId) then 
        Stunned = true
        currentStunToken = currentStunToken + 1
        local myToken = currentStunToken
        
        scheduler.delay(0.2, function()
            if currentStunToken == myToken then Stunned = false end
        end)
    end
end
LocalTracker.AnimationAdded:Connect(onLocalAnimationAdded)

function ToggleDamageLogger(state)
    if not state then
        if connection then connection:Disconnect() connection = nil end
        return
    end
    if connection then return end
    
    connection = RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChild("Humanoid")
        if not hum then return end 

        if lastCharacter and (char.Address ~= lastCharacter.Address) then
            lastCharacter = char
            previousHealth = hum.Health
        end
        local currentHealth = hum.Health
        if currentHealth < previousHealth then
            local damageTaken = previousHealth - currentHealth
            if #TargetCharacters > 0 then
                local activeAnimations = AnimationTracker:Update(TargetCharacters[1]) or {}
                for _, anim in activeAnimations do
                    if not anim.AnimationId or anim.TimePosition < 0.1 then continue end
                    local assetId = tostring(anim.AnimationId)
                    local poolData = GameConfig[assetId]
                    warn(string.format("[DMG DETECTED] Taken: %d | Asset: %s | Style: %s", damageTaken, assetId, poolData and poolData.Style or "Unknown"))
                end
            end
        end
        previousHealth = currentHealth
    end)
end

local AnimationRegistry = {}

local function EvaluateParryTriggers()
    local localCharacter = LocalPlayer.Character
    local localRoot = GetLocalHRP()
    if not localRoot or Stunned then return end

    local currentActiveIds = {}
    
    local rawPing = 0
    if gil and typeof(gil) == "table" and gil.GetPingValue then
        rawPing = gil.GetPingValue()
    elseif typeof(GetPingValue) == "function" then
        rawPing = GetPingValue()
    end
    local pingDelay = (rawPing / 1000) / 2

    for _, character in ipairs(TargetCharacters) do
        local targetRoot = character:FindFirstChild("HumanoidRootPart")
        if not targetRoot then continue end

        local Distance = (targetRoot.Position - localRoot.Position).Magnitude
        if not AutoParryToggle.Get() then continue end
        if Distance > AutoParryRange then continue end

        local activeAnimations = AnimationTracker:Update(character)
        if not activeAnimations or #activeAnimations == 0 then continue end
        local now = os.clock()

        for _, anim in ipairs(activeAnimations) do
            if not anim.AnimationId then continue end
            local animKey = anim.Address or anim
            currentActiveIds[animKey] = true
            local currentTrackTime = anim.TimePosition or 0

            if not AnimationRegistry[animKey] then
                AnimationRegistry[animKey] = {
                    StartTime = now - currentTrackTime,
                    Processed = false,
                    Snapshot = false,
                    LastTime = currentTrackTime,
                }
            end
            
            local regData = AnimationRegistry[animKey]
            if regData.LastTime and (currentTrackTime < regData.LastTime - 0.1) then
                regData.Processed = false
                regData.StartTime = now - currentTrackTime
            end
            regData.LastTime = currentTrackTime

            local attackConfig = GameConfig[tostring(anim.AnimationId)]
            if not attackConfig then continue end

            local startTime = regData.StartTime
            local currentTime = now - startTime
            local baseTime = attackConfig.ParryTime or DefaultParryTime
            local parryStart = baseTime - pingDelay
            local parryEnd = baseTime + ParryWindow

            if regData.Processed then continue end

            if attackConfig.ParryFunction then
                regData.Processed = true
                task.spawn(function() attackConfig.ParryFunction(character) end)
                continue
            end

            if currentTime >= parryStart and currentTime <= parryEnd then
                if not regData.Snapshot then
                    regData.Snapshot = true
                    if math.random(1, 100) > ProbabilityToParry then
                        regData.Processed = true
                        continue
                    end
                end
                BlockStart()
                PendingParryTimestamp = now
            end
        end
    end

    for key in pairs(AnimationRegistry) do
        if not currentActiveIds[key] then AnimationRegistry[key] = nil end
    end
end

local function ProcessEspAndLogging()
    for i = #TargetCharacters, 1, -1 do
        local character = TargetCharacters[i]
        local tracker = EspTrackers[character]
        
        if tracker and not tracker.ChangeText then
            EspTrackers[character] = nil
            table.remove(TargetCharacters, i)
            continue
        end

        local activeAnimations = AnimationTracker:Update(character) or {}
        local lines = {}
        
        if #activeAnimations == 0 then 
            tracker:ChangeText("CurrentlyPlaying", "None", COLOR_WHITE)
            continue 
        end 

        for _, anim in ipairs(activeAnimations) do
            if not anim.AnimationId then continue end
            local assetId = anim.AnimationId
            local numericId = tonumber(string.match(tostring(assetId), "%d+"))
            if numericId and table.find(IgnoreIds, numericId) then continue end
            
            local poolData = GameConfig[tostring(assetId)]
            local resolvedName = poolData and poolData.DisplayName or anim.Name
            
            if not poolData then  
                if not AnimationsLoggedCache[assetId] then
                    AnimationsLoggedCache[assetId] = { Name = resolvedName }
                    table.insert(AnimationsLoggedOrder, assetId)
                    UpdateClipboardSection()
                end
            end

            table.insert(lines, string.format("%s | ID: %s | Time: %.2f", tostring(resolvedName), tostring(assetId), anim.TimePosition or 0))
        end
        tracker:ChangeText("CurrentlyPlaying", table.concat(lines, "\n"), COLOR_WHITE)
    end
end

local function ClearAllEspTrackers()
    for char, tracker in pairs(EspTrackers) do
        if tracker and tracker.Destroy then            
            if ESP_Utility.TrackersToUpdate[tracker] then ESP_Utility.TrackersToUpdate[tracker] = nil end
            tracker:Destroy()
        end
    end
    table.clear(EspTrackers)
end

local function UpdateTargetCharacters(charactersList)
    ClearAllEspTrackers()
    table.clear(TargetCharacters)

    for _, character in charactersList do
        table.insert(TargetCharacters, character)
        if character and character:FindFirstChild("HumanoidRootPart") then
            local tracker = ESP_Utility.NewTracker(character.HumanoidRootPart, character.Name, COLOR_RED)
            if tracker and tracker.Name then tracker:AddText("CurrentlyPlaying", nil, "???") end
            EspTrackers[character] = tracker
        end
    end
end

local function CycleEvent()
    local allCharacters = GetAllCharactersInFolder()
    if not SelectedFolder or not allCharacters then UpdateTargetCharacters({}) return end

    local localRoot = GetLocalHRP()
    if not localRoot then return end

    local validCharacters = {}
    for _, char in ipairs(allCharacters) do
        if char == LocalPlayer.Character then continue end
        local targetRoot = char:FindFirstChild("HumanoidRootPart")
        if targetRoot then
            local distance = (localRoot.Position - targetRoot.Position).Magnitude
            if distance <= MaxCycleRange then
                table.insert(validCharacters, { Character = char, Distance = distance })
            end
        end
    end
    
    if #validCharacters == 0 then
        CurrentIndex = 1
        UpdateTargetCharacters({})
        return
    end

    table.sort(validCharacters, function(a, b) return a.Distance < b.Distance end)

    if MuliTarget.Get() then
        local finalTargets = {}
        for i = 1, math.min(3, #validCharacters) do table.insert(finalTargets, validCharacters[i].Character) end
        UpdateTargetCharacters(finalTargets)
    else
        CurrentIndex = (CurrentIndex % #validCharacters) + 1
        local targetIndex = AutoTargetNearest.Get() and 1 or CurrentIndex
        UpdateTargetCharacters({validCharacters[targetIndex].Character})
    end
end

UIS.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == CycleKeybind then CycleEvent() end
end)

local lastAnimationCheck = 0
local LastCycleCheck = 0

RunService.Heartbeat:Connect(function()
    local now = os.clock()
    ParryTask()
    EvaluateParryTriggers()
    scheduler.update()

    if (now - lastAnimationCheck >= 0) then
        lastAnimationCheck = now
        if #TargetCharacters >= 1 then ProcessEspAndLogging() end
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then LocalTracker:Update(LocalPlayer.Character) end
    end
    if (now - LastCycleCheck >= 0.5) then
        LastCycleCheck = now
        if AutoTargetNearest.Get() then CycleEvent() end
    end
end)
